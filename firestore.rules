rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (request.auth.token.email_verified == true && (
          request.auth.token.email == "nxxoteam@gmail.com" ||
          request.auth.token.email == "admin@rockymods.com" ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
        )) ||
        request.auth.token.email == "master_admin@rockymods.com"
      );
    }

    // Settings: Everyone can read, only admins can write
    match /settings/{settingId} {
      allow read, write: if true;
    }

    // UserStats: Everyone can read and write
    match /userStats/{userId} {
      allow read, write: if true;
    }

    // Sessions: Everyone can read and write sessions
    match /sessions/{sessionId} {
      allow read, write: if true;
    }

    // Keys: Everyone can read and write keys
    match /keys/{keyId} {
      allow read, write: if true;
    }

    // LinkLogs: Everyone can read and write
    match /linkLogs/{logId} {
      allow read, write: if true;
    }

    // Users: Everyone can read and write
    match /users/{userId} {
      allow read, write: if true;
    }
    
    // Default allow for everything else
    match /{path=**} {
      allow read, write: if true;
    }
  }
}
