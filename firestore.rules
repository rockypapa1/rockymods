rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: keys
    // Document ID: auto-generated
    // Fields:
    //   - value: string (required, length > 0) - The actual key string
    //   - isUsed: boolean (required) - Whether the key has been claimed
    //   - createdAt: number (required) - Timestamp of creation
    //   - usedAt: number (optional) - Timestamp of when it was used
    //
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.email == 'admin@rockymods.com';
    }

    function isValidKey(data) {
      return data.keys().hasAll(['value', 'isUsed', 'createdAt']) &&
             data.value is string && data.value.size() > 0 && data.value.size() < 100 &&
             data.isUsed is bool &&
             data.createdAt is number &&
             (!('usedAt' in data) || data.usedAt is number);
    }

    function isValidSettings(data) {
      return data.keys().hasAll(['linkShortenerUrl', 'linkShortenerApiToken']) &&
             data.linkShortenerUrl is string && data.linkShortenerUrl.size() > 0 && data.linkShortenerUrl.size() < 500 &&
             data.linkShortenerApiToken is string && data.linkShortenerApiToken.size() > 0 && data.linkShortenerApiToken.size() < 200;
    }

    match /settings/{settingId} {
      // Anyone can read settings
      allow read: if true;
      
      // Only admins can create, update, or delete settings
      allow create: if isAdmin() && isValidSettings(request.resource.data);
      allow update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /keys/{keyId} {
      // Anyone can read unused keys to generate one, admins can read all
      allow read: if isAdmin() || resource.data.isUsed == false;
      
      // Only admins can create or delete keys
      allow create: if isAdmin() && isValidKey(request.resource.data);
      allow delete: if isAdmin();
      
      // Users can only update a key to mark it as used
      allow update: if (isAdmin() && isValidKey(request.resource.data)) || (
        isValidKey(request.resource.data) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isUsed', 'usedAt']) &&
        resource.data.isUsed == false &&
        request.resource.data.isUsed == true &&
        request.resource.data.value == resource.data.value &&
        request.resource.data.createdAt == resource.data.createdAt
      );
    }
  }
}
