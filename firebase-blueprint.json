{
  "entities": {
    "Key": {
      "title": "Key",
      "description": "A premium mod menu key",
      "type": "object",
      "properties": {
        "value": { "type": "string" },
        "isUsed": { "type": "boolean" },
        "createdAt": { "type": "number" },
        "usedAt": { "type": "number" }
      },
      "required": ["value", "isUsed", "createdAt"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "linkShortenerUrl": { "type": "string" },
        "linkShortenerApiToken": { "type": "string" }
      },
      "required": ["linkShortenerUrl", "linkShortenerApiToken"]
    }
  },
  "firestore": {
    "keys/{keyId}": {
      "schema": { "$ref": "#/entities/Key" },
      "description": "Stores all generated keys"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global application settings"
    }
  }
}
