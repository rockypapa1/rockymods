{
  "entities": {
    "Key": {
      "title": "Key",
      "description": "A premium mod menu key",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "status": { "type": "string", "enum": ["available", "used"] },
        "createdAt": { "type": "number" },
        "usedAt": { "type": "number" },
        "usedBy": { "type": "string" },
        "sessionId": { "type": "string" }
      },
      "required": ["key", "status", "createdAt"]
    },
    "Session": {
      "title": "Session",
      "description": "A session for key generation",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fingerprint": { "type": "string" },
        "createdAt": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "claimed"] },
        "claimedAt": { "type": "number" }
      },
      "required": ["userId", "createdAt", "status"]
    },
    "Settings": {
      "title": "Settings",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "linkShortener1Url": { "type": "string" },
        "linkShortener1ApiToken": { "type": "string" },
        "linkShortener2Url": { "type": "string" },
        "linkShortener2ApiToken": { "type": "string" },
        "announcement": { "type": "string" },
        "maintenanceMode": { "type": "boolean" }
      },
      "required": ["linkShortener1Url", "linkShortener1ApiToken", "linkShortener2Url", "linkShortener2ApiToken"]
    },
    "UserStats": {
      "title": "UserStats",
      "description": "Tracks daily key generations for users",
      "type": "object",
      "properties": {
        "totalKeysGenerated": { "type": "number" },
        "lastGeneratedAt": { "type": "number" },
        "dailyCount": { "type": "number" },
        "firstGeneratedAt": { "type": "number" }
      },
      "required": ["totalKeysGenerated", "lastGeneratedAt", "dailyCount"]
    },
    "LinkLog": {
      "title": "LinkLog",
      "description": "Logs of link shortener usage and key claims",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "shortenerIndex": { "type": "number" },
        "timestamp": { "type": "number" },
        "status": { "type": "string", "enum": ["redirected", "claimed"] },
        "sessionId": { "type": "string" },
        "keyId": { "type": "string" }
      },
      "required": ["userId", "timestamp", "status"]
    }
  },
  "firestore": {
    "keys/{keyId}": {
      "schema": { "$ref": "#/entities/Key" },
      "description": "Stores all generated keys"
    },
    "sessions/{sessionId}": {
      "schema": { "$ref": "#/entities/Session" },
      "description": "Stores active key generation sessions"
    },
    "settings/{settingId}": {
      "schema": { "$ref": "#/entities/Settings" },
      "description": "Stores global application settings"
    },
    "userStats/{userId}": {
      "schema": { "$ref": "#/entities/UserStats" },
      "description": "Tracks daily key generations for users (ID is hashed IP or fingerprint)"
    },
    "linkLogs/{logId}": {
      "schema": { "$ref": "#/entities/LinkLog" },
      "description": "Logs of link shortener redirections and claims"
    }
  }
}
